generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Candidate {
  id              String       @id @default(uuid())
  name            String
  role            String
  summary         String
  skills          String       // comma-separated
  location        String?
  isProcessed     Boolean      @default(false)
  hiddenGemScore  Int?
  trajectoryNotes String?
  adjacencyScore  Int?
  githubUrl       String?
  portfolioUrl    String?
  pipelineStage   String       @default("applied") // applied | screened | interview | offer | hired | rejected
  redFlags        String?      // JSON string array of flag strings
  createdAt       DateTime     @default(now())

  experiences     Experience[]
  education       Education?
  notes           CandidateNote[]
}

model Experience {
  id          String    @id @default(uuid())
  role        String
  company     String
  duration    String
  description String
  bullets     String    // JSON string

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Education {
  id          String    @id @default(uuid())
  degree      String
  school      String
  year        String

  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model JobDescription {
  id          String   @id @default(uuid())
  title       String
  content     String
  createdAt   DateTime @default(now())
}

model CandidateNote {
  id          String    @id @default(uuid())
  content     String
  createdAt   DateTime  @default(now())

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}
